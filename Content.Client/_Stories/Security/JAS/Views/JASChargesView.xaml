<controls:JASChargesView
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._Stories.Security.JAS.Views"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:uiControls="clr-namespace:Content.Client.UserInterface.Controls">
    <PanelContainer Name="JASCharges" Margin="0 0 0 5">
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat
                BackgroundColor="#000000"
                BorderColor="#3F3F3F"/>
        </PanelContainer.PanelOverride>
        <GridContainer Rows="2" Columns="1">
            <GridContainer Name="Categories" Access="Public" Visible="True" Columns="6">
            </GridContainer>
            <uiControls:HighDivider Modulate="#3F3F3F" SetHeight="5"/>
            <ScrollContainer HScrollEnabled="False" VerticalExpand="True" HorizontalExpand="True" SetWidth="1100" SetHeight="350">
                <GridContainer Name="ChargesList" Access="Public" Visible="True" HorizontalAlignment="Center" Margin="0 5 0 0">
                </GridContainer>
            </ScrollContainer>
        </GridContainer>
    </PanelContainer>
</controls:JASChargesView>
